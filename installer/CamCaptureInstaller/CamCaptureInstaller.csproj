<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>CamCaptureInstaller</AssemblyName>
    <RootNamespace>CamCaptureInstaller</RootNamespace>
    <ApplicationIcon>assets\camcapture.ico</ApplicationIcon>
    <Title>CamCapture 高速版 Installer</Title>
    <Product>CamCapture 高速版 Installer</Product>
    <Company>Imaging</Company>
    <Version>1.3.0</Version>
    <FileVersion>1.3.0.0</FileVersion>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>false</SelfContained>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="payload\payload.zip" />
    <Content Include="assets\camcapture.ico" />
  </ItemGroup>
</Project>
